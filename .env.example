# Plasec / Avigilon Unity Server
PLASEC_HOST=192.0.2.1
PLASEC_USERNAME=admin
PLASEC_PASSWORD=your_password_here

# AccessGrid API Configuration
AG_ACCOUNT_ID=your_account_id_here
